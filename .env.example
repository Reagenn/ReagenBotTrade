SOLANA_STRONG_BUY_SCORE=70
SOLANA_STALE_PAIR_PENALTY_SCORE=18
SOLANA_STALE_SIGNAL_HOURS=12
SOLANA_FRESH_SIGNAL_HOURS=4
SOLANA_MUST_BUY_FRESH_HOURS=3
SOLANA_WATCHLIST_STALE_HOURS=18
# Gate DexScreener sebelum GoPlus/Helius/Birdeye (hemat API)
DEXSCREENER_MIN_LIQUIDITY_USD=10000
DEXSCREENER_MIN_VOLUME_24H_USD=50000
DEXSCREENER_MIN_FDV_USD=20000
# Jumlah token yang dianalisis per siklus (default 40). Naikkan perlahan — lebih banyak = lebih banyak RPC/Birdeye.
SOLANA_TOKEN_UNIVERSE_LIMIT=40
# Daftar timeframe: koin tidak hilang saat pindah 1H→4H→1D (retensi registry, jam)
SOLANA_TIMEFRAME_REGISTRY_RETENTION_HOURS=168
SOLANA_TIMEFRAME_LIST_LIMIT=50
SOLANA_SMART_MONEY_TABLE_LIMIT=40
SOLANA_WHALE_TABLE_LIMIT=40
SOLANA_HELIUS_WALLETS_PER_CYCLE=14
# Tier longgar (Opsi C): token score tinggi bisa masuk Alpha/FIRE tanpa akumulasi smart wallet
SOLANA_TIER_RELAX=true
SOLANA_ALPHA_MOMENTUM_SCORE=62
SOLANA_FIRE_MOMENTUM_SCORE=72
GOPLUS_ACCESS_TOKEN=
BIRDEYE_API_KEY=
# Starter+: /smart-money/v1/token/list (token smart money). Lite+: fallback token_trending.
# Smart wallet diisi otomatis via /defi/v2/tokens/top_traders (jalan di Lite+).
SOLANA_SKIP_BIRDEYE_SMART_MONEY=false
BIRDEYE_TOP_TRADERS_PER_TOKEN=3
BIRDEYE_SMART_MONEY_TRADER_LOOKUP_TOKENS=8
BIRDEYE_ENRICH_WALLET_PNL=2
BIRDEYE_TOKEN_HOLDER_LIMIT=30
BIRDEYE_MIN_GAP_MS=2800
BIRDEYE_QUEUE_DELAY_MS=2800
BIRDEYE_RETRY_DELAY_MS=3500
BIRDEYE_CU_PAUSE_MS=300000
BIRDEYE_TOP_TRADERS_PER_TOKEN=2
BIRDEYE_SMART_MONEY_TRADER_LOOKUP_TOKENS=5
SOLANA_PNL_WALLETS_PER_CYCLE=2
# Sumber win rate wallet watchlist Birdeye: helius | birdeye | auto (helius dulu, fallback birdeye)
SOLANA_WALLET_PNL_SOURCE=helius
SOLANA_WALLET_PNL_DELAY_MS=350
SOLANA_HOLDER_CACHE_TTL_MS=1200000
SOLANA_HOLDER_FULL_EVERY_N_CYCLES=3
SOLANA_TOKEN_ANALYTICS_PER_CYCLE=3
SOLANA_TOKEN_ANALYTICS_PRIORITY=6
SOLANA_WHALE_HOLDER_USD=10000
SOLANA_HOLDER_HISTORY_MAX=84
# Watchlist Birdeye berat — refresh tiap N siklus (default 5) agar monitor tidak "diam" lama
SOLANA_WATCHLIST_EVERY_N_CYCLES=5
# Ambang Phoenix Scanner (dashboard tab Phoenix)
SOLANA_PHOENIX_FIRE_SCORE=90
SOLANA_PHOENIX_CANDIDATE_SCORE=75
SOLANA_PHOENIX_PRE_IGN_SCORE=55
HELIUS_API_KEY=
# Base URL Helius Enhanced Transactions (alternatif: https://api-mainnet.helius-rpc.com)
HELIUS_API_BASE_URL=https://api.helius.xyz
# Kalkulator win rate mandiri (walletAnalyzer.js)
WALLET_ANALYZER_SWAP_LIMIT=50
WALLET_ANALYZER_SMART_MONEY_THRESHOLD=70
# Paper trading simulasi Solana (tradingSimulator.js)
SIM_TAKE_PROFIT_PCT=50
SIM_STOP_LOSS_PCT=20
SOLANA_PAPER_TRADING_ENABLED=true
SOLANA_PAPER_OUTPUT_PATH=./solana-paper-trading-output.json
SOLANA_PAPER_BUY_SOL=0.1
SOLANA_PAPER_MAX_OPEN=12
SOLANA_PAPER_BUY_TRIGGERS=fire,must_buy,buy_zone,strong_buy,phoenix_fire,phoenix_candidate
# Harga TP/SL posisi terbuka via priceFetcher.js (Birdeye → Jupiter → DexScreener)
SOLANA_PAPER_USE_PRICE_FETCHER=true
# Filter keamanan & momentum sebelum paper buy (tokenValidator.js)
SOLANA_PAPER_USE_TOKEN_VALIDATOR=true
TOKEN_VALIDATOR_MIN_SCORE=75
TOKEN_VALIDATOR_MIN_LIQUIDITY_SOL=50
TOKEN_VALIDATOR_MAX_MOMENTUM_5M_PCT=300
TOKEN_VALIDATOR_CACHE_MS=90000
PRICE_FETCH_TIMEOUT_MS=4500
PRICE_FETCH_BATCH_DELAY_MS=150
# Jupiter v2 sering 404 — modul otomatis coba /price/v3
JUPITER_PRICE_PATH=/price/v2
# Bot dari @BotFather; chat ID dari @userinfobot atau npm run telegram:test (setelah /start ke bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Alert Telegram saat koin baru muncul di Phoenix FIRE / Alpha / Watchlist / Must Buy
SOLANA_TELEGRAM_ALERT_APPEARANCES=true
# Registry Phoenix & briefing — koin tidak hilang cepat (jam, default 7 hari)
SOLANA_SIGNAL_REGISTRY_RETENTION_HOURS=168
SOLANA_PHOENIX_CARDS_LIMIT=48
SOLANA_BRIEFING_FIRE_LIMIT=12
SOLANA_BRIEFING_ALPHA_LIMIT=16
SOLANA_BRIEFING_WATCHLIST_LIMIT=24

# CEX Volume Spike Breakout (Bybit / Bitget — public API saja)
CEX_BOT_ENABLED=true
CEX_EXCHANGE=bybit
CEX_OUTPUT_PATH=./cex-paper-output.json
CEX_SCAN_INTERVAL_MS=60000
CEX_TRACKER_POLL_MS=5000
CEX_STARTING_BALANCE_USDT=1000
CEX_POSITION_SIZE_USDT=100
CEX_TAKE_PROFIT_PCT=3
CEX_STOP_LOSS_PCT=1.5
# Filter selektif (cexMonitor.js): EMA200 15m, wick rejection, TP/SL dinamis ATR
CEX_TREND_TIMEFRAME=15m
CEX_EMA_TREND_PERIOD=200
CEX_MAX_UPPER_WICK_RATIO=0.35
CEX_ATR_PERIOD=14
CEX_ATR_SL_MULTIPLIER=1.5
CEX_ATR_TP_MULTIPLIER=3
CEX_OHLCV_1M_LIMIT=60
CEX_OHLCV_15M_LIMIT=220
CEX_VOLUME_SPIKE_MULTIPLIER=3
CEX_UNIVERSE_LIMIT=40
CEX_MIN_QUOTE_VOLUME_24H=500000
CEX_API_TIMEOUT_MS=12000
