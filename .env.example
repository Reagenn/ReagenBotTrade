# Kosongkan atau biarkan public — jika HELIUS_API_KEY ada, otomatis pakai Helius RPC (hindari 429)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_USE_HELIUS_RPC=true
SOLANA_RPC_DELAY_MS=450
SOLANA_RPC_MAX_RETRIES=6
SOLANA_RPC_RETRY_BASE_MS=2000
SOLANA_BALANCE_WALLETS_PER_TOKEN=10
SOLANA_SKIP_UNLINKED_BALANCE_RPC=true
SOLANA_WATCHLIST_PATH=./solana_watchlist.json
SOLANA_MONITOR_STATE_PATH=./solana-monitor-state.json
SOLANA_MONITOR_OUTPUT_PATH=./solana-smart-money-output.json
SOLANA_MONITOR_POLL_MS=120000
SOLANA_MIN_LIQUIDITY_USD=25000
SOLANA_STRONG_LIQUIDITY_USD=100000
SOLANA_MIN_VOLUME_24H_USD=50000
SOLANA_MIN_WHALE_ACCUMULATION_USD=1000
SOLANA_MIN_LINKED_TRADER_VOLUME_USD=500
SOLANA_MIN_SMART_WALLET_BUY_COUNT=2
SOLANA_DISCOVERY_LIMIT=8
SOLANA_MIN_PAIR_AGE_HOURS=6
SOLANA_MAX_PAIR_AGE_HOURS=720
SOLANA_MAX_FDV_TO_LIQUIDITY_RATIO=40
SOLANA_RUG_RISK_SELL_BIAS_THRESHOLD=2.2
SOLANA_RUG_RISK_NEGATIVE_PRICE_CHANGE_THRESHOLD=-35
